@using Capa_Modelo.Login
@model LoginViewModel

@{
    ViewBag.Title = "Login";
}

<style>
    .login-panel {
        height: 90vh;
    }

    .video-panel {
        height: 90vh;
    }

    .boton {
        color: #ffffff;
        background: #4f8c4c;
    }

</style>

<div class="row min-vh-100 m-0 justify-content-center align-items-center">


    <div class="col-lg-6 position-relative p-0 video-panel">
       <video autoplay
               loop
               muted
               playsinline
               src="~/videos/video-presentacion-24-05-23.mp4"
               style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;">
        </video>
        <div class="p-5" style="z-index: 1;">
            <div class="copyright mt-4 mb-0 p-3 ui-bg-soft rounded-5" id="copyright">
                <span class="ui-text-primary"><strong>CONTACTO:</strong></span>
                <div class="my-3">
                    <span class="ui-text-primary">> </span><span class="ui-text-muted"> soporte.ti@cobefar.com.pe</span><br />
                    <span class="ui-text-primary">>> </span><span class="ui-text-muted"> coordinador.ti@cobefar.com.pe</span><br />
                    <span class="ui-text-primary">>>> </span><span class="ui-text-muted"> coordinador.desarrollo@cobefar.com.pe</span><br />
                    <span class="ui-text-primary">>>>> </span><span class="ui-text-muted">  soporte.desarrollo@cobefar.com.pe</span>
                </div>

                <div>
                    <span class="ui-text-muted">© Todos los derechos reservados - COBEFAR S.A.C</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 px-4 py-3 bg-white d-flex align-items-center justify-content-center login-panel"  style="opacity:0.95; box-shadow: rgba(0,0,0,.19) 0px 10px 20px;">
         <div>
            <div class="text-center mb-4">
                <img src="~/img/LOGO CORPORACIÓN COBEFAR.png" class="img-fluid" width="400" />
            </div>

            <form asp-controller="Login" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-2">
                    <label asp-for="usuario" class="col-form-label text-cobefar font-weight-bold"></label>
                    <input asp-for="usuario"  class="form-control border-success" type="text" placeholder="Ingrese su usuario" />
                    <span asp-validation-for="usuario" class="text-danger"></span>
                </div>
                <div class="form-group mb-2">
                    <label asp-for="password" class="col-form-label text-cobefar font-weight-bold"></label>
                    <input asp-for="password" class="form-control border-success" id="clave" type="password" placeholder="Ingrese su contraseña" />
                    <span asp-validation-for="password" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <button type="submit" id="btnLogin" class="btn rounded-5 boton" >Ingresar</button>
                </div>
            </form>

            
        </div>
    </div>
</div>



