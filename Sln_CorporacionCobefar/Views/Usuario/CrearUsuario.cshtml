@using Capa_Modelo.Login
@model UsuarioCreacionViewModel

@{
    ViewData["TItle"] = "Crear Usuario";
}

<div class="form-container">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form id="formCrear" asp-action="CrearUsuario" method="post">

        <h5 class="mb-3 ui-text-primary">Registrar Usuario</h5>

        <div class="row">
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="NombresUsuario" class="form-label"></label>
                    <input type="text" class="form-control ui-bg-soft rounded-4 no-focus-readonly" asp-for="NombresUsuario" readonly="@(Model.EsEdicion ? "readonly" : null)">
                    <span asp-validation-for="NombresUsuario" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="ApellidosUsuario" class="form-label"></label>
                    <input type="text" class="form-control ui-bg-soft rounded-4 no-focus-readonly" asp-for="ApellidosUsuario" readonly="@(Model.EsEdicion ? "readonly" : null)">
                    <span asp-validation-for="ApellidosUsuario" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label asp-for="EmailUsuario" class="form-label"></label>
                    <input type="text" class="form-control ui-bg-soft rounded-4" asp-for="EmailUsuario">
                    <span asp-validation-for="EmailUsuario" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="mb-3">
                    <label class="form-label">Rol</label>
                    <select asp-for="IdRol"
                    asp-items="Model.Roles"
                            class="form-select no-focus-readonly"
                            id="ddlRoles" disabled="@(Model.EsEdicion ? "disabled" : null)">
                    </select>
                    <span asp-validation-for="IdRol" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    <label class="form-label" asp-for="UsuarioConcatenado"></label>
                    <input type="text"
                           class="form-control ui-bg-soft rounded-4 no-focus-readonly"
                    id="txtUsuario"
                    asp-for="UsuarioConcatenado"
                    readonly >
                    <span asp-validation-for="UsuarioConcatenado" class="text-danger"></span>
                </div>
            </div>
            <input type="hidden" asp-for="PrefijoRol" id="hdnPrefijoRol" />
            <input type="hidden" asp-for="SecuenciaPorRol" id="hdnSecuenciaPorRol" />
           
            <input type="hidden" asp-for="IdUsuario"  />
        </div>

        @if (Model.EsEdicion) // mostrar solo al editar
        {
            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Activo</label>
                        <input type="text" class="form-control ui-bg-soft rounded-4 no-focus-readonly"
                                   value="@(Model.activo == 1 ? "SI" : "NO")" readonly>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Fecha de Registro</label>
                        <input type="text" asp-for="FechaRegistro" class="form-control ui-bg-soft rounded-4 no-focus-readonly"
                                   value="@(Model.FechaRegistro?.ToString("dd/MM/yyyy"))" readonly>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Contraseña"></label>
                        <input type="password" class="form-control ui-bg-soft rounded-4 no-focus-readonly" asp-for="Contraseña" placeholder="Ingrese nueva contraseña">
                        <span asp-validation-for="Contraseña" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label" asp-for="RepetirContraseña"></label>
                        <input type="password" class="form-control ui-bg-soft rounded-4 no-focus-readonly" asp-for="RepetirContraseña" placeholder="Repetir nueva contraseña">
                        <span asp-validation-for="RepetirContraseña" class="text-danger"></span>
                    </div>
                </div>
            </div>
        }


        <div class="d-flex gap-2">
            <button type="submit" class="btn boton">@(Model.EsEdicion ? "Actualizar Usuario" : "Registrar Usuario")</button>
            <a class="btn btn-danger" asp-controller="Usuario" asp-action="Index">Volver</a>
        </div>
    </form>



</div>
@section Scripts {

    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById("ddlRoles").addEventListener("change", function () {
            const idRol = this.value;
            const txtUsuario = document.getElementById("txtUsuario");
                 const hdnPrefijoRol = document.getElementById("hdnPrefijoRol");
        const hdnSecuenciaPorRol = document.getElementById("hdnSecuenciaPorRol");

            if (idRol === "") {
                txtUsuario.value = "";
                   hdnPrefijoRol.value = "";
            hdnSecuenciaPorRol.value = "";
                return;
            }

            fetch(`/Usuario/ObtenerUsuarioPorRol?idRol=${idRol}`)
                .then(response => response.json())
                .then(data => {
                    txtUsuario.value = data.usuario ?? "";
                       hdnPrefijoRol.value = data.prefijoRol ?? "";
                hdnSecuenciaPorRol.value = data.secuenciaPorRol ?? "";
                })
                .catch(error => {
                    console.error(error);
                    txtUsuario.value = "";
                });
        });
    </script>

}